#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/shared.bash
source "${DIR}/../lib/shared.bash"
# shellcheck source=lib/tools.bash
source "${DIR}/../lib/tools.bash"

# ---------------------------------------------------------------------------
# Parse explicit tools from plugin config
# ---------------------------------------------------------------------------

read_configured_tools() {
  CONFIGURED_TOOLS=()
  local i=0
  while true; do
    local var="BUILDKITE_PLUGIN_SETUP_RUNTIME_TOOLS_${i}"
    local value="${!var:-}"
    if [ -z "$value" ]; then break; fi
    CONFIGURED_TOOLS+=("$value")
    i=$((i + 1))
  done
}

main() {
  echo "~~~ :toolbox: Setting up runtime"

  local dir_cfg
  dir_cfg="$(plugin_cfg dir)"
  if [ -n "$dir_cfg" ]; then
    WORKING_DIRECTORY="$dir_cfg"
  else
    WORKING_DIRECTORY="${BUILDKITE_BUILD_CHECKOUT_PATH:-${PWD}}"
  fi

  # Ensure mise is installed
  ensure_mise

  # Install explicitly configured tools (tools: ["go@1.22", "node@20"])
  read_configured_tools

  if [ "${#CONFIGURED_TOOLS[@]}" -gt 0 ]; then
    log_info "Installing configured tools: ${CONFIGURED_TOOLS[*]}"

    for tool_spec in "${CONFIGURED_TOOLS[@]}"; do
      run_mise install "$tool_spec"
      run_mise use --global "$tool_spec"
    done
  fi

  # Auto-detect from repo config files
  local auto_detect
  auto_detect="$(plugin_cfg_default auto-detect true)"
  local auto_detected_tools=()

  if [ "$auto_detect" = "true" ]; then
    if [ -f "${WORKING_DIRECTORY}/mise.toml" ] \
      || [ -f "${WORKING_DIRECTORY}/.mise.toml" ] \
      || [ -f "${WORKING_DIRECTORY}/.tool-versions" ]; then
      log_info "Installing tools from repo config"
      (cd "$WORKING_DIRECTORY" && run_mise install)

      # Collect auto-detected tools for post-install setup.
      # mise ls --current outputs lines like "go  1.22.5  ~/.tool-versions"
      local name version _rest
      while read -r name version _rest; do
        if [ -n "$name" ] && [ -n "$version" ]; then
          auto_detected_tools+=("${name}@${version}")
        fi
      done < <(cd "$WORKING_DIRECTORY" && run_mise ls --current 2>/dev/null || true)
    else
      log_debug "No mise/tool-versions config found in ${WORKING_DIRECTORY}"
    fi
  fi

  # Export tool environment
  if [ -z "${BUILDKITE_ENV_FILE:-}" ]; then
    log_error "BUILDKITE_ENV_FILE is not set"
    exit 1
  fi

  append_export MISE_DATA_DIR "$MISE_DIR"
  append_export MISE_TRUSTED_CONFIG_PATHS "$WORKING_DIRECTORY"
  append_export MISE_YES "1"

  export MISE_DATA_DIR="$MISE_DIR"
  export MISE_TRUSTED_CONFIG_PATHS="$WORKING_DIRECTORY"
  export MISE_YES="1"

  pushd "$WORKING_DIRECTORY" > /dev/null
  apply_mise_env
  popd > /dev/null

  # Tool-specific post-install setup & verification
  # Combine explicit and auto-detected tools, deduplicating by tool name.
  local -A seen_tools=()
  local all_tools=()

  for tool_spec in ${CONFIGURED_TOOLS[@]+"${CONFIGURED_TOOLS[@]}"}; do
    local tool
    tool="$(resolve_tool_name "${tool_spec%%@*}")"
    seen_tools["$tool"]=1
    all_tools+=("$tool_spec")
  done

  for tool_spec in ${auto_detected_tools[@]+"${auto_detected_tools[@]}"}; do
    local tool
    tool="$(resolve_tool_name "${tool_spec%%@*}")"
    if [ -z "${seen_tools[$tool]:-}" ]; then
      seen_tools["$tool"]=1
      all_tools+=("$tool_spec")
    fi
  done

  for tool_spec in ${all_tools[@]+"${all_tools[@]}"}; do
    local tool="${tool_spec%%@*}"
    local version="${tool_spec#*@}"
    tool_post_install "$tool" "$version"
  done

  echo "~~~ :white_check_mark: Runtime ready"
  for tool_spec in ${all_tools[@]+"${all_tools[@]}"}; do
    local tool="${tool_spec%%@*}"
    tool_verify "$tool"
  done
}

main "$@"
